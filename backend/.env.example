# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/version_ops?schema=public

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
PORT=3333
FRONTEND_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080
NODE_ENV=development

# ─────────────────────────────────────────
# Admin Auth
# ─────────────────────────────────────────

JWT_SECRET=jwtsecret
JWT_EXPIRES_IN=8h


SUPER_ADMIN_EMAIL=admin
SUPER_ADMIN_PASSWORD=**********  
SUPER_ADMIN_NAME=Ustaad JI


LOG_LEVEL=info
